<ResourceDictionary
    x:Class="NINA.Plugins.PolarAlignment.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalon="clr-namespace:NINA.Plugins.PolarAlignment.Avalon"
    xmlns:behavior="clr-namespace:NINA.WPF.Base.Behaviors;assembly=NINA.WPF.Base"
    xmlns:converters="clr-namespace:NINA.Plugins.PolarAlignment.Converters"
    xmlns:coreconverters="clr-namespace:NINA.Core.Utility.Converters;assembly=NINA.Core"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:NINA.Plugins.PolarAlignment"
    xmlns:ninactrl="clr-namespace:NINA.CustomControlLibrary;assembly=NINA.CustomControlLibrary"
    xmlns:ns="clr-namespace:NINA.Core.Locale;assembly=NINA.Core"
    xmlns:oapa="clr-namespace:NINA.Plugins.PolarAlignment.OAPA"
    xmlns:properties="clr-namespace:NINA.Plugins.PolarAlignment.Properties"
    xmlns:rules="clr-namespace:NINA.Core.Utility.ValidationRules;assembly=NINA.Core"
    xmlns:s="clr-namespace:System;assembly=mscorlib"
    xmlns:util="clr-namespace:NINA.Core.Utility;assembly=NINA.Core"
    xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit">
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <coreconverters:InverseBooleanToVisibilityCollapsedConverter x:Key="InverseBooleanToVisibilityConverter" />
    <coreconverters:BooleanToVisibilityHiddenConverter x:Key="BooleanToVisibilityHiddenConverter" />
    <s:String x:Key="DefaultMoveRateToolTip">Default RA-axis rate TPPA requests when it moves the mount between the first three measurement points in automatic mode.</s:String>
    <s:String x:Key="DefaultEastDirectionToolTip">Controls whether the initial automatic RA sweep is sent in the eastward direction.</s:String>
    <s:String x:Key="DefaultTargetDistanceToolTip">Default angular separation between the TPPA measurement points during the initial RA-only sweep. Larger values make the mount move farther between the first, second, and third solve.</s:String>
    <s:String x:Key="DefaultSearchRadiusToolTip">Initial plate-solve search radius, in degrees, used by TPPA. The setting is clamped to the range 30 to 180.</s:String>
    <s:String x:Key="MoveTimeoutFactorToolTip">Multiplier applied to the computed automatic RA-move timeout. TPPA calculates the timeout as move distance divided by move rate, then multiplies by this factor.</s:String>
    <s:String x:Key="DefaultAzimuthOffsetToolTip">Default azimuth offset used when TPPA creates start coordinates instead of starting from the current position. In the southern hemisphere TPPA applies this offset relative to 180 degrees.</s:String>
    <s:String x:Key="DefaultAltitudeOffsetToolTip">Default altitude offset added when TPPA creates start coordinates instead of starting from the current position.</s:String>
    <s:String x:Key="AlignmentToleranceToolTip">Arcminute threshold used for automatic completion when the reported total error falls at or below it. Automated adjustments require this value to be non-zero.</s:String>
    <s:String x:Key="AltitudeErrorColorToolTip">Color used for the altitude-error overlay elements in the live TPPA display.</s:String>
    <s:String x:Key="AzimuthErrorColorToolTip">Color used for the azimuth-error overlay elements in the live TPPA display.</s:String>
    <s:String x:Key="TotalErrorColorToolTip">Color used for the total-error overlay elements in the live TPPA display.</s:String>
    <s:String x:Key="TargetCircleColorToolTip">Color used for the target-circle overlay that shows the correction destination.</s:String>
    <s:String x:Key="SuccessColorToolTip">Color used for success-state TPPA overlay elements.</s:String>
    <s:String x:Key="LogErrorToolTip">When enabled, TPPA writes the current longitude, latitude, altitude error, azimuth error, and total error to its polar-alignment log during continuous updates.</s:String>
    <s:String x:Key="RefractionAdjustmentToolTip">Controls whether TPPA computes the polar error with refraction-aware topocentric coordinates.</s:String>
    <s:String x:Key="UseContinuousErrorEstimatorToolTip">When enabled, TPPA uses the experimental time-aware continuous estimator for live correction error. When disabled, TPPA uses the legacy image-plane calculation.</s:String>
    <s:String x:Key="StopTrackingWhenDoneToolTip">When enabled, TPPA turns sidereal tracking off in its cleanup path after the run ends.</s:String>
    <s:String x:Key="AutoPauseToolTip">When enabled, TPPA pauses itself after each continuous-correction update.</s:String>
    <s:String x:Key="PolarAlignmentSystemToolTip">Selects which hardware adjustment system TPPA exposes as the active alignment system: None, UPAS, or OAPA.</s:String>
    <s:String x:Key="ReverseAzimuthToolTip">Negates azimuth-axis nudge and move commands sent through the selected hardware system.</s:String>
    <s:String x:Key="ReverseAltitudeToolTip">Negates altitude-axis nudge and move commands sent through the selected hardware system.</s:String>
    <s:String x:Key="AzimuthBacklashCompensationToolTip">If non-zero and the azimuth movement direction changes, TPPA sends an extra negative-then-positive relative X move of this size after the main move.</s:String>
    <s:String x:Key="AutomatedAdjustmentsToolTip">When enabled, TPPA calls its automated correction routine and sends nudge commands through the selected hardware system during the correction phase.</s:String>
    <s:String x:Key="AutomatedAdjustmentSettleTimeToolTip">Number of seconds TPPA waits after each automated adjustment before continuing.</s:String>
    <s:String x:Key="ResetSettingsToolTip">Shows a confirmation dialog and then resets the TPPA plugin settings to their default values.</s:String>
    <s:String x:Key="AlignmentSystemConnectToolTip">Creates the selected hardware system, scans available serial ports for a matching device, and starts status polling.</s:String>
    <s:String x:Key="AlignmentSystemDisconnectToolTip">Disposes the current hardware connection and stops status polling.</s:String>
    <s:String x:Key="AlignmentSystemSpeedToolTip">Speed value passed to hardware move commands for this axis.</s:String>
    <s:String x:Key="AlignmentSystemGearRatioToolTip">Scale factor used when converting between hardware motor units and the axis units shown by TPPA.</s:String>
    <DataTemplate x:Key="Three Point Polar Alignment_Options">
        <TabControl>
            <i:Interaction.Behaviors>
                <behavior:BubbleScrollEvent />
            </i:Interaction.Behaviors>
            <TabItem Header="Settings">
                <Grid Margin="0,5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="Default Move Rate"
                            ToolTip="{StaticResource DefaultMoveRateToolTip}" />
                        <TextBox
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding DefaultMoveRate}"
                            ToolTip="{StaticResource DefaultMoveRateToolTip}" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Default East Direction"
                            ToolTip="{StaticResource DefaultEastDirectionToolTip}" />
                        <CheckBox
                            Grid.Row="1"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsChecked="{Binding DefaultEastDirection}"
                            ToolTip="{StaticResource DefaultEastDirectionToolTip}" />
                        <TextBlock
                            Grid.Row="2"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Default Target Distance"
                            ToolTip="{StaticResource DefaultTargetDistanceToolTip}" />

                        <ninactrl:UnitTextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding DefaultTargetDistance}"
                            ToolTip="{StaticResource DefaultTargetDistanceToolTip}"
                            Unit="°" />
                        <TextBlock
                            Grid.Row="3"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Default Search Radius"
                            ToolTip="{StaticResource DefaultSearchRadiusToolTip}" />
                        <ninactrl:UnitTextBox
                            Grid.Row="3"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding DefaultSearchRadius}"
                            ToolTip="{StaticResource DefaultSearchRadiusToolTip}"
                            Unit="°" />

                        <TextBlock
                            Grid.Row="4"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Axis move timeout factor"
                            ToolTip="{StaticResource MoveTimeoutFactorToolTip}" />
                        <ninactrl:UnitTextBox
                            Grid.Row="4"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding MoveTimeoutFactor}"
                            ToolTip="{StaticResource MoveTimeoutFactorToolTip}"
                            Unit="x" />

                        <TextBlock
                            Grid.Row="5"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Default azimuth offset from pole"
                            ToolTip="{StaticResource DefaultAzimuthOffsetToolTip}" />
                        <ninactrl:UnitTextBox
                            Grid.Row="5"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding DefaultAzimuthOffset}"
                            ToolTip="{StaticResource DefaultAzimuthOffsetToolTip}"
                            Unit="°" />

                        <TextBlock
                            Grid.Row="6"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Default altitude offset from pole"
                            ToolTip="{StaticResource DefaultAltitudeOffsetToolTip}" />
                        <ninactrl:UnitTextBox
                            Grid.Row="6"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding DefaultAltitudeOffset}"
                            ToolTip="{StaticResource DefaultAltitudeOffsetToolTip}"
                            Unit="°" />

                        <TextBlock
                            Grid.Row="7"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Default Alignment Tolerance"
                            ToolTip="{StaticResource AlignmentToleranceToolTip}" />
                        <ninactrl:UnitTextBox
                            Grid.Row="7"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding AlignmentTolerance}"
                            ToolTip="{StaticResource AlignmentToleranceToolTip}"
                            Unit="arcmin" />

                        <TextBlock
                            Grid.Row="8"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Altitude Error Color"
                            ToolTip="{StaticResource AltitudeErrorColorToolTip}" />
                        <xceed:ColorPicker
                            Grid.Row="8"
                            Grid.Column="1"
                            Width="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedColor="{Binding AltitudeErrorColor}"
                            ToolTip="{StaticResource AltitudeErrorColorToolTip}" />
                        <TextBlock
                            Grid.Row="9"
                            VerticalAlignment="Center"
                            Text="Azimuth Error Color"
                            ToolTip="{StaticResource AzimuthErrorColorToolTip}" />
                        <xceed:ColorPicker
                            Grid.Row="9"
                            Grid.Column="1"
                            Width="80"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedColor="{Binding AzimuthErrorColor}"
                            ToolTip="{StaticResource AzimuthErrorColorToolTip}" />
                        <TextBlock
                            Grid.Row="10"
                            VerticalAlignment="Center"
                            Text="Total Error Color"
                            ToolTip="{StaticResource TotalErrorColorToolTip}" />
                        <xceed:ColorPicker
                            Grid.Row="10"
                            Grid.Column="1"
                            Width="80"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedColor="{Binding TotalErrorColor}"
                            ToolTip="{StaticResource TotalErrorColorToolTip}" />
                        <TextBlock
                            Grid.Row="11"
                            VerticalAlignment="Center"
                            Text="Target Circle Color"
                            ToolTip="{StaticResource TargetCircleColorToolTip}" />
                        <xceed:ColorPicker
                            Grid.Row="11"
                            Grid.Column="1"
                            Width="80"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedColor="{Binding TargetCircleColor}"
                            ToolTip="{StaticResource TargetCircleColorToolTip}" />
                        <TextBlock
                            Grid.Row="12"
                            VerticalAlignment="Center"
                            Text="Sucessful Step Color"
                            ToolTip="{StaticResource SuccessColorToolTip}" />
                        <xceed:ColorPicker
                            Grid.Row="12"
                            Grid.Column="1"
                            Width="80"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedColor="{Binding SuccessColor}"
                            ToolTip="{StaticResource SuccessColorToolTip}" />
                        <TextBlock
                            Grid.Row="13"
                            VerticalAlignment="Center"
                            Text="Log polar alignment error adjustments?"
                            ToolTip="{StaticResource LogErrorToolTip}" />
                        <CheckBox
                            Grid.Row="13"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsChecked="{Binding LogError}"
                            ToolTip="{StaticResource LogErrorToolTip}" />
                        <TextBlock
                            Grid.Row="14"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Adjust for refraction?"
                            ToolTip="{StaticResource RefractionAdjustmentToolTip}" />
                        <StackPanel
                            Grid.Row="14"
                            Grid.Column="1"
                            Orientation="Horizontal">
                            <CheckBox
                                MinWidth="80"
                                Margin="5,5,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                IsChecked="{Binding RefractionAdjustment}"
                                ToolTip="{StaticResource RefractionAdjustmentToolTip}" />
                            <TextBlock
                                Margin="5,5,0,0"
                                Text="This option is currently under test. Feedback if this results in better polar alignment is appreciated!"
                                Visibility="{Binding RefractionAdjustment, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Row="15"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Stop Tracking when done?"
                            ToolTip="{StaticResource StopTrackingWhenDoneToolTip}" />
                        <CheckBox
                            Grid.Row="15"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsChecked="{Binding StopTrackingWhenDone}"
                            ToolTip="{StaticResource StopTrackingWhenDoneToolTip}" />
                        <TextBlock
                            Grid.Row="16"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Auto pause between continuous exposures?"
                            ToolTip="{StaticResource AutoPauseToolTip}" />
                        <CheckBox
                            Grid.Row="16"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsChecked="{Binding AutoPause}"
                            ToolTip="{StaticResource AutoPauseToolTip}" />
                        <TextBlock
                            Grid.Row="17"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Use continuous error estimator?"
                            ToolTip="{StaticResource UseContinuousErrorEstimatorToolTip}" />
                        <StackPanel
                            Grid.Row="17"
                            Grid.Column="1"
                            Orientation="Horizontal">
                            <CheckBox
                                MinWidth="80"
                                Margin="5,5,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                IsChecked="{Binding UseContinuousErrorEstimator}"
                                ToolTip="{StaticResource UseContinuousErrorEstimatorToolTip}" />
                            <TextBlock
                                Margin="5,5,0,0"
                                Text="This option is under test and experimental"
                                Visibility="{Binding UseContinuousErrorEstimator, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Row="18"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Polar Alignment System"
                            ToolTip="{StaticResource PolarAlignmentSystemToolTip}" />
                        <ComboBox
                            Grid.Row="18"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedValue="{Binding SelectedPolarAlignmentSystem}"
                            ToolTip="{StaticResource PolarAlignmentSystemToolTip}">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type local:PolarAlignmentSystemType}">
                                    <local:PolarAlignmentSystemType>None</local:PolarAlignmentSystemType>
                                    <local:PolarAlignmentSystemType>UPAS</local:PolarAlignmentSystemType>
                                    <local:PolarAlignmentSystemType>OAPA</local:PolarAlignmentSystemType>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                        <TextBlock
                            Grid.Row="19"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Reverse Azimuth Axis?"
                            ToolTip="{StaticResource ReverseAzimuthToolTip}"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <CheckBox
                            Grid.Row="19"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsChecked="{Binding ActiveSystem.ReverseAzimuth}"
                            ToolTip="{StaticResource ReverseAzimuthToolTip}"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            Grid.Row="20"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Reverse Altitude Axis?"
                            ToolTip="{StaticResource ReverseAltitudeToolTip}"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <CheckBox
                            Grid.Row="20"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="5,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsChecked="{Binding ActiveSystem.ReverseAltitude}"
                            ToolTip="{StaticResource ReverseAltitudeToolTip}"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            Grid.Row="21"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Azimuth backlash compensation"
                            ToolTip="{StaticResource AzimuthBacklashCompensationToolTip}"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ninactrl:UnitTextBox
                            Grid.Row="21"
                            Grid.Column="1"
                            MinWidth="80"
                            Margin="0,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding ActiveSystem.XBacklashCompensation}"
                            ToolTip="{StaticResource AzimuthBacklashCompensationToolTip}"
                            Unit="steps"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            Grid.Row="22"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center"
                            Text="Do automated adjustments?"
                            ToolTip="{StaticResource AutomatedAdjustmentsToolTip}"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <StackPanel
                            Grid.Row="22"
                            Grid.Column="1"
                            Orientation="Horizontal">
                            <CheckBox
                                MinWidth="80"
                                Margin="5,5,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                IsChecked="{Binding ActiveSystem.DoAutomatedAdjustments}"
                                ToolTip="{StaticResource AutomatedAdjustmentsToolTip}"
                                Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Grid Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    Margin="5,5,0,0"
                                    VerticalAlignment="Center"
                                    FontStyle="Italic"
                                    Text="This option is under test and experimental"
                                    Visibility="{Binding ActiveSystem.DoAutomatedAdjustments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>
                        <Grid Grid.Row="23" Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,5,0,0"
                                VerticalAlignment="Center"
                                Text="Automated adjustment settle time"
                                ToolTip="{StaticResource AutomatedAdjustmentSettleTimeToolTip}"
                                Visibility="{Binding ActiveSystem.DoAutomatedAdjustments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                        <Grid
                            Grid.Row="23"
                            Grid.Column="1"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ninactrl:UnitTextBox
                                MinWidth="80"
                                Margin="5,5,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{Binding ActiveSystem.AutomatedAdjustmentSettleTime}"
                                ToolTip="{StaticResource AutomatedAdjustmentSettleTimeToolTip}"
                                Unit="s"
                                Visibility="{Binding ActiveSystem.DoAutomatedAdjustments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                        <Grid
                            Grid.Row="24"
                            Grid.ColumnSpan="2"
                            Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,5,0,0"
                                FontStyle="Italic"
                                Text="Make sure to set your gear ratio to achieve 1 arcminute per step for each axis!"
                                Visibility="{Binding ActiveSystem.DoAutomatedAdjustments, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                        <Button
                            Grid.Row="25"
                            Margin="0,20,0,0"
                            Command="{Binding ResetSettingsCommand}"
                            ToolTip="{StaticResource ResetSettingsToolTip}">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource ButtonForegroundBrush}"
                                Text="Reset All Settings" />
                        </Button>
                    </Grid>
                    <GroupBox
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Header="Avalon Polar Alignment System"
                        Visibility="{Binding IsUPASSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid DataContext="{Binding UniversalPolarAlignmentVM}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Command="{Binding ConnectCommand}"
                                    ToolTip="{StaticResource AlignmentSystemConnectToolTip}"
                                    Visibility="{Binding Connected, Converter={StaticResource InverseBooleanToVisibilityCollapsedConverter}}">
                                    Test Connect
                                </Button>
                                <Button
                                    Command="{Binding DisconnectCommand}"
                                    ToolTip="{StaticResource AlignmentSystemDisconnectToolTip}"
                                    Visibility="{Binding Connected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    Disconnect
                                </Button>
                            </Grid>
                            <ContentPresenter Grid.Row="1" Content="{Binding UniversalPolarAlignmentVM}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Header="OAPA Polar Alignment System"
                        Visibility="{Binding IsOAPASelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid DataContext="{Binding UniversalPolarAlignmentOAPAVM}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Command="{Binding ConnectCommand}"
                                    ToolTip="{StaticResource AlignmentSystemConnectToolTip}"
                                    Visibility="{Binding Connected, Converter={StaticResource InverseBooleanToVisibilityCollapsedConverter}}">
                                    Test Connect
                                </Button>
                                <Button
                                    Command="{Binding DisconnectCommand}"
                                    ToolTip="{StaticResource AlignmentSystemDisconnectToolTip}"
                                    Visibility="{Binding Connected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    Disconnect
                                </Button>
                            </Grid>
                            <ContentPresenter Grid.Row="1" Content="{Binding UniversalPolarAlignmentOAPAVM}" />
                        </Grid>
                    </GroupBox>

                </Grid>
            </TabItem>
            <TabItem Header="Workflow">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <i:Interaction.Behaviors>
                        <behavior:BubbleScrollEvent />
                    </i:Interaction.Behaviors>
                    <StackPanel Margin="12">
                        <Border
                            Padding="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel>
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Measure, solve, adjust, verify." />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="TPPA first measures three plate-solved positions to reconstruct the mount axis, then it continuously solves while you adjust the mount. The safest way to use it is to get close, then verify with a fresh run."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <GroupBox Margin="0,12,0,0" Header="Quick Start">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="1. Connect the camera and confirm plate solving works on the exact optical setup you will use." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="2. Confirm site latitude, longitude, and elevation are correct in the active N.I.N.A. profile."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="3. Pick a reasonably high field toward the pole for your hemisphere."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="4. Use automatic mode if the driver supports primary-axis movement; otherwise use Manual Mode and provide RA-only motion yourself."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="5. If the first run starts far off, use it to get close and then rerun TPPA for final verification."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Automatic And Manual Modes">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Automatic mode" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Text="TPPA slews to the start field if needed and moves the primary axis between the three measurement points using the mount driver."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontWeight="SemiBold"
                                    Text="Manual mode" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Text="Use this when the driver cannot perform automated RA motion. With a telescope connection TPPA can still watch driver coordinates; without one it must infer the movement purely from repeated solves."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Measurement Phase">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Move only the RA axis between the first three points." />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="In automatic mode TPPA performs those moves for you. In Manual Mode you provide the same RA-only motion yourself."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="Do not adjust altitude, azimuth, or declination during this phase."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Correction Phase">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Once the initial error is shown, adjust only mount altitude and azimuth." />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="Keep tracking on, let TPPA continue solving, and avoid normal slews or camera rotation during the live correction loop."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="You can left-click a star in the live view so the overlay follows a more convenient reference star, but the physical rule does not change: only altitude and azimuth adjustments belong here."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Field Choice">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Prefer a field toward the pole for your hemisphere and at least about 15° above the horizon when practical." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="Also avoid choosing a run that will cross the meridian, to avoid any pier collisions."
                                    TextWrapping="Wrap" />
                                <Border
                                    Margin="0,10,0,0"
                                    Padding="12"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock
                                                Grid.Row="0"
                                                Margin="0,0,0,6"
                                                HorizontalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Text="Pole Side" />
                                            <Grid
                                                Grid.Row="1"
                                                Width="400"
                                                Height="300">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Viewbox
                                                    Grid.Column="1"
                                                    Width="350"
                                                    Height="300"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    IsHitTestVisible="False"
                                                    Stretch="Uniform">
                                                    <Grid
                                                        Width="240"
                                                        Height="240"
                                                        SnapsToDevicePixels="True"
                                                        UseLayoutRounding="True">
                                                        <Grid>
                                                            <Grid.Clip>
                                                                <EllipseGeometry
                                                                    Center="120,120"
                                                                    RadiusX="120"
                                                                    RadiusY="120" />
                                                            </Grid.Clip>
                                                            <Ellipse
                                                                Width="240"
