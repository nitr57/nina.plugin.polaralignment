                                    FontSize="16"
                                    Foreground="{StaticResource AltitudeErrorColor}"
                                    Text="{Binding PolarErrorDetermination.InitialMountAxisAltitudeError}" />
                            </Viewbox>
                        </UniformGrid>
                    </GroupBox>
                </Border>
                <Border
                    Grid.Column="2"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,0">
                    <GroupBox>
                        <GroupBox.Header>
                            <Viewbox
                                Height="40"
                                Stretch="Uniform"
                                StretchDirection="DownOnly">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Foreground="{StaticResource TotalErrorColor}"
                                    Text="Total Error" />
                            </Viewbox>
                        </GroupBox.Header>

                        <UniformGrid VerticalAlignment="Center" Rows="3">
                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="36"
                                    Foreground="{StaticResource TotalErrorColor}"
                                    Text="{Binding PolarErrorDetermination.CurrentMountAxisTotalError}" />
                            </Viewbox>
                            <ninactrl:LoadingControl
                                Grid.Column="1"
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                LoadingImageBrush="{StaticResource TotalErrorColor}"
                                Visibility="{Binding WaitingForUpdate, Converter={StaticResource BooleanToVisibilityHiddenConverter}}" />

                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="{StaticResource TotalErrorColor}"
                                    Text="{Binding PolarErrorDetermination.InitialMountAxisTotalError}" />
                            </Viewbox>
                        </UniformGrid>
                    </GroupBox>
                </Border>
            </Grid>

            <Grid
                Grid.Row="2"
                Grid.ColumnSpan="3"
                Visibility="{Binding PolarErrorDetermination, Converter={StaticResource NullToVisibilityCollapsedConverter}}">

                <Viewbox
                    Height="60"
                    Stretch="Uniform"
                    StretchDirection="DownOnly"
                    Visibility="{Binding PolarErrorDetermination.InitialErrorLarge, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="36"
                            FontWeight="Bold">
                            Initial Polar Alignment error is large. Correction phase will be unreliable.
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Center" FontSize="36">Please bring the mount closer to polar alignment and do another run to verify the result!</TextBlock>
                    </StackPanel>

                </Viewbox>

                <Viewbox
                    Height="60"
                    Stretch="Uniform"
                    StretchDirection="DownOnly"
                    Visibility="{Binding PolarErrorDetermination.InitialErrorHuge, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="36"
                            FontWeight="Bold">
                            Calculated error is huge. Either the mount is far off alignment or the polar alignment calculation was unable to determine the result.
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Center" FontSize="36">Make sure your location is set correctly, that the mount is roughly pointing to the pole and that only the right ascension axis was moved in between the three points!</TextBlock>
                    </StackPanel>

                </Viewbox>
            </Grid>
            <Grid
                Grid.Row="3"
                Grid.ColumnSpan="4"
                Visibility="{Binding PolarErrorDetermination, Converter={StaticResource NullToVisibilityCollapsedConverter}}">
                <StackPanel Orientation="Vertical">
                    <Viewbox
                        Height="60"
                        Stretch="Uniform"
                        StretchDirection="DownOnly"
                        Visibility="{Binding PolarErrorDetermination.DeclinationSpreadLarge, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="36"
                                FontWeight="Bold"
                                Text="Mount's reported declination changed by " />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="36"
                                FontWeight="Bold"
                                Text="{Binding PolarErrorDetermination.DeclinationSpreadArcsec, StringFormat=N2}" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="36"
                                FontWeight="Bold"
                                Text=" arcseconds between measurements. This may affect polar alignment accuracy." />
                        </StackPanel>
                    </Viewbox>
                    <Grid Visibility="{Binding UseContinuousErrorEstimator, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Viewbox
                            Height="60"
                            Stretch="Uniform"
                            StretchDirection="DownOnly"
                            Visibility="{Binding PolarErrorDetermination.CurrentCorrectionFieldNearEastWest, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Vertical">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold">
                                    <Run Text="Current correction field is within " />
                                    <Run Text="{Binding PolarErrorDetermination.CurrentCorrectionFieldDistanceToEastWestDegrees, Mode=OneWay, StringFormat=N1}" />
                                    <Run Text="° of exact east or west." />
                                </TextBlock>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    FontWeight="Bold">
                                    Continuous correction is less reliable here. Prefer a field farther from exact east or west if the solution is unstable.
                                </TextBlock>
                            </StackPanel>
                        </Viewbox>
                    </Grid>
                </StackPanel>
            </Grid>
            <GroupBox
                Grid.Row="4"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch"
                Visibility="{Binding UniversalPolarAlignmentVM.Connected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <GroupBox.Header>
                    <TextBlock Text="Avalon Polar Alignment System" />
                </GroupBox.Header>
                <Grid HorizontalAlignment="Stretch">
                    <!--  Manual UPA Control  -->
                    <ContentPresenter Content="{Binding UniversalPolarAlignmentVM}" Visibility="{Binding UniversalPolarAlignmentVM.DoAutomatedAdjustments, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <!--  Automated UPA Status  -->
                    <Grid HorizontalAlignment="Stretch" Visibility="{Binding UniversalPolarAlignmentVM.DoAutomatedAdjustments, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock FontSize="16" Text="Azimuth: " />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{Binding UniversalPolarAlignmentVM.PositionX, StringFormat=N2}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock FontSize="16" Text="Altitude: " />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{Binding UniversalPolarAlignmentVM.PositionY, StringFormat=N2}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Text="Automatic Mode" />
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type avalon:UniversalPolarAlignmentVM}">
        <Grid Visibility="{Binding Connected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <s:Single x:Key="NegativeDotOne">-0.1</s:Single>
                <s:Single x:Key="DotOne">0.1</s:Single>
                <s:Single x:Key="NegativeOne">-1</s:Single>
                <s:Single x:Key="One">1</s:Single>
                <s:Single x:Key="NegativeTen">-10</s:Single>
                <s:Single x:Key="Ten">10</s:Single>
            </Grid.Resources>
            <GroupBox Header="Azimuth">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" ToolTip="{StaticResource AlignmentSystemSpeedToolTip}">
                            Speed
                        </TextBlock>
                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            SelectedValue="{Binding XSpeed}"
                            ToolTip="{StaticResource AlignmentSystemSpeedToolTip}">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type s:Int32}">
                                    <s:Int32>100</s:Int32>
                                    <s:Int32>200</s:Int32>
                                    <s:Int32>300</s:Int32>
                                    <s:Int32>400</s:Int32>
                                    <s:Int32>500</s:Int32>
                                    <s:Int32>600</s:Int32>
                                    <s:Int32>700</s:Int32>
                                    <s:Int32>800</s:Int32>
                                    <s:Int32>900</s:Int32>
                                    <s:Int32>1000</s:Int32>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                        <TextBlock
                            Grid.Column="2"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="{StaticResource AlignmentSystemGearRatioToolTip}">
                            GearRatio
                        </TextBlock>
                        <TextBox
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Text="{Binding XGearRatio}"
                            ToolTip="{StaticResource AlignmentSystemGearRatioToolTip}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Text="{Binding PositionX, StringFormat=N2}" />
                        <Grid Grid.Row="1" Visibility="{Binding DoAutomatedAdjustments, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Button
                                Height="25"
                                Margin="0,0,2.5,0"
                                Command="{Binding NudgeXCommand}"
                                CommandParameter="{StaticResource NegativeDotOne}">
                                -0.1
                            </Button>
                            <Button
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,0,0,0"
                                Command="{Binding NudgeXCommand}"
                                CommandParameter="{StaticResource DotOne}">
                                +0.1
                            </Button>
                            <Button
                                Grid.Row="1"
                                Height="25"
                                Margin="0,5,2.5,0"
                                Command="{Binding NudgeXCommand}"
                                CommandParameter="{StaticResource NegativeOne}">
                                -1
                            </Button>
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,5,0,0"
                                Command="{Binding NudgeXCommand}"
                                CommandParameter="{StaticResource One}">
                                +1
                            </Button>
                            <Button
                                Grid.Row="2"
                                Height="25"
                                Margin="0,5,2.5,0"
                                Command="{Binding NudgeXCommand}"
                                CommandParameter="{StaticResource NegativeTen}">
                                -10
                            </Button>
                            <Button
                                Grid.Row="2"
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,5,0,0"
                                Command="{Binding NudgeXCommand}"
                                CommandParameter="{StaticResource Ten}">
                                +10
                            </Button>

                            <TextBox
                                Grid.Row="3"
                                Margin="0,5,2.5,0"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Right"
                                Text="{Binding TargetPositionX}" />
                            <Button
                                Grid.Row="3"
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,5,0,0"
                                Command="{Binding MoveXCommand}">
                                Move
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>

            </GroupBox>
            <GroupBox Grid.Column="1" Header="Altitude">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" ToolTip="{StaticResource AlignmentSystemSpeedToolTip}">
                            Speed
                        </TextBlock>
                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            SelectedItem="{Binding YSpeed}"
                            ToolTip="{StaticResource AlignmentSystemSpeedToolTip}">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type s:Int32}">
                                    <s:Int32>100</s:Int32>
                                    <s:Int32>200</s:Int32>
                                    <s:Int32>300</s:Int32>
                                    <s:Int32>400</s:Int32>
                                    <s:Int32>500</s:Int32>
                                    <s:Int32>600</s:Int32>
                                    <s:Int32>700</s:Int32>
                                    <s:Int32>800</s:Int32>
                                    <s:Int32>900</s:Int32>
                                    <s:Int32>1000</s:Int32>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                        <TextBlock
                            Grid.Column="2"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="{StaticResource AlignmentSystemGearRatioToolTip}">
                            GearRatio
                        </TextBlock>
                        <TextBox
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Text="{Binding YGearRatio}"
                            ToolTip="{StaticResource AlignmentSystemGearRatioToolTip}" />
                    </Grid>
                    <Grid Grid.Row="1" Visibility="{Binding Connected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Text="{Binding PositionY, StringFormat=N2}" />
                        <Grid Grid.Row="1" Visibility="{Binding DoAutomatedAdjustments, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Button
                                Height="25"
                                Margin="0,0,2.5,0"
                                Command="{Binding NudgeYCommand}"
                                CommandParameter="{StaticResource NegativeDotOne}">
                                -0.1
                            </Button>
                            <Button
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,0,0,0"
                                Command="{Binding NudgeYCommand}"
                                CommandParameter="{StaticResource DotOne}">
                                +0.1
                            </Button>
                            <Button
                                Grid.Row="1"
                                Height="25"
                                Margin="0,5,2.5,0"
                                Command="{Binding NudgeYCommand}"
                                CommandParameter="{StaticResource NegativeOne}">
                                -1
                            </Button>
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,5,0,0"
                                Command="{Binding NudgeYCommand}"
                                CommandParameter="{StaticResource One}">
                                +1
                            </Button>
                            <Button
                                Grid.Row="2"
                                Height="25"
                                Margin="0,5,2.5,0"
                                Command="{Binding NudgeYCommand}"
                                CommandParameter="{StaticResource NegativeTen}">
                                -10
                            </Button>
                            <Button
                                Grid.Row="2"
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,5,0,0"
                                Command="{Binding NudgeYCommand}"
                                CommandParameter="{StaticResource Ten}">
                                +10
                            </Button>

                            <TextBox
                                Grid.Row="3"
                                Margin="0,5,2.5,0"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Right"
                                Text="{Binding TargetPositionY}" />
                            <Button
                                Grid.Row="3"
                                Grid.Column="1"
                                Height="25"
                                Margin="2.5,5,0,0"
                                Command="{Binding MoveYCommand}">
                                Move
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type oapa:UniversalPolarAlignmentOAPAVM}">
        <oapa:OAPAControlPanel />
    </DataTemplate>
</ResourceDictionary>
