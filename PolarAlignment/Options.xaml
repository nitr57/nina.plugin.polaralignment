                                                            <Polygon Fill="#D96C6C" Points="120,120 239.54,130.46 240,120 239.54,109.54" />
                                                            <Polygon Fill="#D96C6C" Points="120,120 0.46,109.54 0,120 0.46,130.46" />
                                                            <Ellipse
                                                                Width="240"
                                                                Height="240"
                                                                Margin="0"
                                                                Fill="Transparent"
                                                                Stroke="#D96C6C"
                                                                StrokeThickness="20" />
                                                            <Line
                                                                Opacity="0.35"
                                                                Stroke="#5F6670"
                                                                StrokeDashArray="2,6"
                                                                StrokeThickness="1"
                                                                X1="0"
                                                                X2="240"
                                                                Y1="120"
                                                                Y2="120" />
                                                            <Line
                                                                Opacity="0.35"
                                                                Stroke="#5F6670"
                                                                StrokeDashArray="2,6"
                                                                StrokeThickness="1"
                                                                X1="120"
                                                                X2="120"
                                                                Y1="0"
                                                                Y2="240" />
                                                            <Line
                                                                Opacity="0.25"
                                                                Stroke="#5F6670"
                                                                StrokeDashArray="2,6"
                                                                StrokeThickness="1"
                                                                X1="35.15"
                                                                X2="204.85"
                                                                Y1="35.15"
                                                                Y2="204.85" />
                                                            <Line
                                                                Opacity="0.25"
                                                                Stroke="#5F6670"
                                                                StrokeDashArray="2,6"
                                                                StrokeThickness="1"
                                                                X1="35.15"
                                                                X2="204.85"
                                                                Y1="204.85"
                                                                Y2="35.15" />
                                                            <Ellipse
                                                                Width="200"
                                                                Height="200"
                                                                Margin="20"
                                                                Fill="Transparent"
                                                                Stroke="#8C2F39"
                                                                StrokeThickness="1.5" />
                                                            <Ellipse
                                                                Width="160"
                                                                Height="160"
                                                                Margin="40"
                                                                Fill="Transparent"
                                                                Opacity="0.2"
                                                                Stroke="#5F6670"
                                                                StrokeThickness="1" />
                                                            <Ellipse
                                                                Width="120"
                                                                Height="120"
                                                                Margin="60"
                                                                Fill="Transparent"
                                                                Opacity="0.2"
                                                                Stroke="#5F6670"
                                                                StrokeThickness="1" />
                                                            <Ellipse
                                                                Width="80"
                                                                Height="80"
                                                                Margin="80"
                                                                Fill="Transparent"
                                                                Opacity="0.2"
                                                                Stroke="#5F6670"
                                                                StrokeThickness="1" />
                                                            <Ellipse
                                                                Width="40"
                                                                Height="40"
                                                                Margin="100"
                                                                Fill="Transparent"
                                                                Opacity="0.2"
                                                                Stroke="#5F6670"
                                                                StrokeThickness="1" />
                                                        </Grid>
                                                        <Ellipse
                                                            Width="240"
                                                            Height="240"
                                                            Fill="Transparent"
                                                            Stroke="#5F6670"
                                                            StrokeThickness="1.2" />
                                                        <Ellipse
                                                            Width="14"
                                                            Height="14"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Fill="#D96C6C" />
                                                    </Grid>
                                                </Viewbox>
                                            </Grid>
                                            <StackPanel Grid.Row="2" Margin="0,6,0,0">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Text="Equator Side" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="11"
                                                    Text="Outer edge = horizon, center = exact zenith" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Pole Side means north in the northern hemisphere and south in the southern hemisphere." TextWrapping="Wrap" />
                                            <TextBlock
                                                Margin="0,10,0,0"
                                                FontWeight="SemiBold"
                                                Text="How to read it" />
                                            <StackPanel Margin="0,8,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border
                                                        Width="12"
                                                        Height="12"
                                                        Margin="0,3,8,0"
                                                        Background="#72B37E"
                                                        CornerRadius="2" />
                                                    <TextBlock Text="Green highlights the pole-side region that best satisfies the avoid rules." TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                                    <Border
                                                        Width="12"
                                                        Height="12"
                                                        Margin="0,3,8,0"
                                                        Background="#F3D36A"
                                                        CornerRadius="2" />
                                                    <TextBlock Text="Yellow is usable but less forgiving once you move away from that pole-side sweet spot." TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                                    <Border
                                                        Width="12"
                                                        Height="12"
                                                        Margin="0,3,8,0"
                                                        Background="#D96C6C"
                                                        CornerRadius="2" />
                                                    <TextBlock Text="Red marks the explicit avoid rules: below about 15° altitude, within 5° of exact east or west, and the center point for exact zenith." TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock
                                                Margin="0,10,0,0"
                                                Text="The red ring is the 15° altitude line. The chart uses radius for zenith distance, so moving outward means lower altitude."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="When To Rerun Instead Of Continuing">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Rerun TPPA instead of endlessly chasing the live display when the initial error was large, when the correction loop has been running for several minutes, or when the field is drifting into a worse part of the sky." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="In practice, one coarse run followed by one fine run is often faster and more trustworthy than stretching a single correction loop too far."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Accuracy">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <i:Interaction.Behaviors>
                        <behavior:BubbleScrollEvent />
                    </i:Interaction.Behaviors>
                    <StackPanel Margin="12">
                        <Border
                            Padding="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <TextBlock Text="TPPA is strongest when you use a favorable part of the sky, the plate solves are clean, and the only mount changes are the ones expected for the current phase of the workflow." TextWrapping="Wrap" />
                        </Border>
                        <GroupBox Margin="0,12,0,0" Header="What Improves Accuracy">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Use a fast reliable local solver, correct focal length and pixel size, a start field high enough that all three initial RA-sweep points and the later correction field stay comfortably above the horizon, and a mount that is already roughly aligned before you start the fine pass. For a conservative field choice, prefer about 15° altitude or higher when practical." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If you use refraction correction, accurate site data and sensible weather input matter more."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="What Degrades Accuracy">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="The biggest avoidable mistakes are moving anything except the RA axis during the first three points, and moving anything except mount altitude and azimuth during the correction phase." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="Other common degraders are low-altitude fields, especially if the run drops much below about 15°, exact east or west during correction, zenith, meridian crossings, poor tracking, camera rotation, and plate solves that are right at the edge of the allowed search radius."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Warning States">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="If the initial error is above about 2 degrees, TPPA warns that the correction phase is less reliable. That is a prompt to get closer and then rerun." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If the initial error is above about 10 degrees, check site location, start field, and whether the first three measurements were collected by RA motion only."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If the mount reports noticeable declination spread between measurement points, the three-point result is less trustworthy because the sweep was not a clean RA-only motion."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If TPPA warns that the current correction field is within 5 degrees of exact east or west, the live correction phase is in the east or west warning region. If the live solution is unstable, move to a field farther from exact east or west and rerun."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="How To Interpret A Restless Solution">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="A few arcseconds of movement in the displayed error is normal because TPPA is always solving new frames while the mount is tracking." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="Larger swings usually mean the setup moved mechanically, the field is in a less favorable part of the sky, or enough time has passed that a fresh baseline solve is the better choice."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Troubleshooting">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <i:Interaction.Behaviors>
                        <behavior:BubbleScrollEvent />
                    </i:Interaction.Behaviors>
                    <StackPanel Margin="12">
                        <GroupBox Header="Start Button Disabled">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Check camera connection, telescope connection unless you intentionally chose Manual Mode, mount park state, and filter wheel connection if a specific filter is selected." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If automated adjustments are enabled, alignment tolerance must be greater than zero."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Solve Problems">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Increase the search radius first. Then verify exposure, focal length, pixel size, binning, and that the field is not too low or too sparse." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If solving works elsewhere in N.I.N.A. but not inside TPPA, the search radius is the first knob to adjust because TPPA starts from a tighter solve assumption."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Large Or Nonsensical Error">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Check site latitude and longitude first. Then check whether the initial field was sensible and whether the first three points were collected with RA-only movement." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If the setup started very far from alignment, use one run to get into the right ballpark and then verify with a new run rather than trusting the first correction phase forever."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Unstable Correction">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="A few arcseconds of movement is normal. Larger swings usually mean a weaker field position in the sky, tracking error, or a mechanical shift." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If the correction display keeps drifting while you are not touching the mount, restart TPPA instead of chasing an old solution indefinitely."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Automation And Hardware">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="If automated adjustments do not move, confirm that a supported polar alignment system is selected, that it can connect, and that alignment tolerance is set above zero." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If automation moves in the wrong direction, verify the reverse-axis settings before changing gear ratios or backlash compensation."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="If automation behaves inconsistently, check gear ratio calibration and increase settle time before assuming the math is wrong."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Margin="0,12,0,0" Header="Refraction">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Refraction correction is most useful when the weather input and site information are credible. It does not remove the fact that the atmosphere changes over time, especially at lower altitude." TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Text="Lower fields are generally less forgiving because atmospheric effects and local horizon conditions matter more there, so if you want the most tolerant setup recommendation, prefer about 15° altitude or higher when practical."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DataTemplate>


